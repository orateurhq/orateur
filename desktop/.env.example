# Copy to `.env`, `.env.development`, or `.env.development.local` in this folder.
# (Root `.gitignore` ignores `.env` and `.env.*.local`.)
#
# Defaults are false in `src/debug.ts`. After editing, restart `vite` / `tauri dev`
# — values are inlined at build time.

# Fake recording UI (waveform/timer) without real events — layout only.
# VITE_DEBUG_FAKE_RECORDING=true

# Keep the borderless overlay visible when idle (do not auto-hide after activity stops).
# VITE_DEBUG_OVERLAY_NO_AUTO_HIDE=true
