{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orateur",
  "version": "0.1.0",
  "identifier": "com.orateur.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Orateur",
        "width": 400,
        "height": 132,
        "minWidth": 280,
        "minHeight": 96,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "visible": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "contentProtected": true
      },
      {
        "label": "settings",
        "title": "Orateur — Settings",
        "width": 520,
        "height": 440,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
