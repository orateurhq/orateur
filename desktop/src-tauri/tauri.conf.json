{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orateur",
  "version": "0.2.2",
  "identifier": "com.orateur.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/build-if-needed.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Orateur",
        "width": 280,
        "height": 40,
        "minWidth": 280,
        "minHeight": 40,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "shadow": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "contentProtected": true
      },
      {
        "label": "settings",
        "title": "Orateur — Settings",
        "width": 520,
        "height": 440,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "resources/orateur-pip-spec.txt",
      "resources/install.sh",
      "resources/orateur-launcher"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwRTc4MTE5RTREREIzRkUKUldUK3M5M2tHWUhuSUlxNDQwTFNZRE9DZ1gwdG04N3BCMWNtR0k3QXQ1L1pqZlp2bUxqYm1MN3IK",
      "endpoints": [
        "https://github.com/orateurhq/orateur/releases/latest/download/latest.json"
      ]
    }
  }
}
